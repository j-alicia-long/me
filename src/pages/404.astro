---
import Button from '../components/ui/Button';
import Section from '../components/ui/Section';
import PageTitle from '../components/ui/PageTitle';
import PageDescription from '../components/ui/PageDescription';
import Layout from '../layouts/Layout.astro';
---

<Layout
  description="Page not found. Please check the URL in the address bar and try again."
  title="Not found · Jennifer Long"
>
  <Section>
    <div class="flex flex-col items-start gap-8 sm:gap-10">
      <div class="flex flex-col gap-4 sm:gap-6">
        <PageTitle>
          <div>404</div>
          <div>Page not found</div>
        </PageTitle>
        <PageDescription>
          This corner of my world doesn't exist! How'd you get here?
        </PageDescription>
      </div>
      <Button href="/">Go back home</Button>
    </div>
  </Section>
</Layout>
